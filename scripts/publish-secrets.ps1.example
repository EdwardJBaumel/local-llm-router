# Copy this file to publish-secrets.ps1 (same folder) and paste your token.
# publish-secrets.ps1 is gitignored — never commit the real file.
#
#   Copy-Item .\scripts\publish-secrets.ps1.example .\scripts\publish-secrets.ps1
#   notepad .\scripts\publish-secrets.ps1
#
# Create tokens:
#   Production: https://pypi.org/manage/account/token/
#   TestPyPI:   https://test.pypi.org/manage/account/token/

$PyPIToken = "pypi-PASTE-YOUR-TOKEN-HERE"

# Optional separate TestPyPI token (leave empty to reuse $PyPIToken for -TestPyPI)
$TestPyPIToken = ""
